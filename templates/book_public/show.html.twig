{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto mt-10 px-4">

    <a href="{{ path('app_books_index') }}" class="text-sm text-gray-500 hover:text-gray-700 transition-colors mb-6 inline-block">
        ← Retour à la liste
    </a>

    <div class="bg-white rounded-xl shadow p-8 flex flex-col gap-5">

        <h1 class="font-bold text-2xl text-gray-800">{{ book.title }}</h1>

        <hr class="border-gray-100">

        <div class="grid grid-cols-2 gap-4 text-sm">
            <div class="flex flex-col gap-1">
                <span class="text-gray-400 uppercase tracking-wide text-xs">Auteur</span>
                <span class="text-gray-700 font-medium">✍️ {{ book.author.name }}</span>
            </div>
            <div class="flex flex-col gap-1">
                <span class="text-gray-400 uppercase tracking-wide text-xs">Année</span>
                <span class="text-gray-700 font-medium">📅 {{ book.year ? book.year|date('Y') : '—' }}</span>
            </div>
            <div class="flex flex-col gap-1">
                <span class="text-gray-400 uppercase tracking-wide text-xs">Catégorie</span>
                <span class="text-gray-700 font-medium">🏷️ {{ book.category.name }}</span>
            </div>
        </div>

        <hr class="border-gray-100">

        <div class="flex flex-col gap-2">
            <span class="text-gray-400 uppercase tracking-wide text-xs">Description</span>
            <p class="text-gray-600 leading-relaxed">{{ book.description }}</p>
        </div>

    </div>
</section>
{% endblock %}