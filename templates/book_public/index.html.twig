{% extends 'base.html.twig' %}

{% block title %}Liste des livres{% endblock %}

{% block body %}
<section class="p-6 max-w-7xl mx-auto">
    <h1 class="font-bold text-2xl mb-6">Les livres</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {% for book in books %}
            <div class="bg-white rounded-xl shadow hover:shadow-md transition-shadow p-5 flex flex-col gap-3">
                <h2 class="font-semibold text-lg text-gray-800">{{ book.title }}</h2>
                <div class="text-sm text-gray-500 flex flex-col gap-1">
                    {% if book.year %}
                        <span>📅 {{ book.year|date('Y') }}</span>
                    {% endif %}
                    <span>✍️ {{ book.author.name }}</span>
                </div>
                <a href="{{ path('app_books_show', {'id': book.id}) }}"
                   class="mt-auto text-center bg-blue-500 hover:bg-blue-600 text-white text-sm rounded-lg px-4 py-2 cursor-pointer transition-colors">
                    Voir le détail
                </a>
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}