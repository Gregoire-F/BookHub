{% extends 'base.html.twig' %}

{% block title %}BookHub - Accueil{% endblock %}

{% block body %}
<section class="max-w-5xl bg-gray-800 text-white mx-auto p-4 mt-6">
    <div class="flex justify-center mb-4"><h1 class="bold text-4xl">Bienvenue sur BookHub</h1></div>
    <div class="flex justify-center"><p>Découvrez notre catalogue de livres et d'auteurs.</p></div>
</section>
    <h1>Bienvenue sur BookHub</h1>
    <p>Découvrez notre catalogue de livres et d'auteurs.</p>


    <h2>Aperçu de notre selection</h2>
    {% for book in books %}
        <div>
            <a href="{{ path('app_books_show', {'id': book.id}) }}">{{ book.title }}</a>
            - {{ book.author.name }} ({{ book.year ? book.year|date('Y') : '' }})
        </div>
    {% endfor %}


{% endblock %}
