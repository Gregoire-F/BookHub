{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
    <form method="post">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                Vous êtes identifié tel que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Se déconnecter</a>
            </div>
        {% endif %}
        <section class="max-w-4xl bg-gray-800 text-white rounded mx-auto mt-6 p-4">  
            <h1 class="text-xl mb-3 font-semi-bold">Connectez-vous</h1>
            <label for="username">Email</label>
            <input class="px-4 py-2 bg-gray-100 border-white" type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
            <label for="password">Mot de passe</label>
            <input class="px-4 py-2 bg-gray-100 border-white" type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
        
        {#
            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
            See https://symfony.com/doc/current/security/remember_me.html

            <div class="checkbox mb-3">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Remember me</label>
            </div>
        #}

            <button class="bg-green-500 hover:bg-green-600 px-4 py-2 text-white rounded-lg cursor-pointer ml-2" type="submit">
                Se connecter
            </button>
        </section>  
    </form>
{% endblock %}
