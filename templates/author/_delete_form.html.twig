<form method="post" action="{{ path('app_author_delete', {'id': author.id}) }}"
      onsubmit="return confirm('Confirmer la suppression ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ author.id) }}">
    <button class="bg-red-500 hover:bg-red-600 text-white rounded-lg px-4 py-2 text-sm transition-colors cursor-pointer">
        Supprimer
    </button>
</form>
