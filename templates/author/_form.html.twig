{{ form_start(form, { attr: { class: 'flex flex-col gap-5' } }) }}

    <div class="flex flex-col gap-1">
        {{ form_label(form.name, 'Nom', { label_attr: { class: 'text-sm font-medium text-gray-700' } }) }}
        {{ form_widget(form.name, { attr: { class: 'border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400' } }) }}
        {{ form_errors(form.name) }}
    </div>

    <button type="submit"
            class="bg-blue-500 hover:bg-blue-600 text-white rounded-lg px-6 py-2 text-sm transition-colors cursor-pointer self-start">
        {{ button_label|default('Enregistrer') }}
    </button>

{{ form_end(form) }}
