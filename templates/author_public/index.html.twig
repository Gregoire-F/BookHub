{% extends 'base.html.twig' %}

{% block title %}Liste des auteurs{% endblock %}

{% block body %}
<section class="p-6 max-w-5xl mx-auto">
    <h1 class="font-bold text-2xl mb-6">Les auteurs</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for author in authors %}
            <div class="bg-white rounded-xl shadow p-5 flex flex-col gap-3">
                <h2 class="font-semibold text-lg text-gray-800">✍️ {{ author.name }}</h2>

                {% if author.book|length > 0 %}
                    <ul class="text-sm text-gray-600 flex flex-col gap-1">
                        {% for book in author.book %}
                            <li>
                                <a href="{{ path('app_books_show', {'id': book.id}) }}"
                                   class="text-blue-500 hover:text-blue-700 transition-colors">
                                    {{ book.title }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <span class="text-sm text-gray-400 italic">Aucun livre enregistré</span>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}
