{% extends 'base.html.twig' %}

{% block title %}{{ category.name }}{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto mt-8 px-4">
    <a href="{{ path('app_category_index') }}"
       class="text-sm text-gray-500 hover:text-gray-700 transition-colors mb-6 inline-block">
        ← Retour à la liste
    </a>

    <div class="bg-white rounded-xl shadow p-8 flex flex-col gap-5">
        <h1 class="font-bold text-2xl text-gray-800">{{ category.name }}</h1>
        <hr class="border-gray-100">

        <div class="flex flex-col gap-1 text-sm">
            <span class="text-gray-400 uppercase tracking-wide text-xs">ID</span>
            <span class="text-gray-700">{{ category.id }}</span>
        </div>

        <hr class="border-gray-100">

        <div class="flex gap-3 items-center">
            <a href="{{ path('app_category_edit', {'id': category.id}) }}"
               class="bg-gray-700 hover:bg-gray-800 text-white rounded-lg px-4 py-2 text-sm transition-colors">
                Modifier
            </a>
            {{ include('category/_delete_form.html.twig') }}
        </div>
    </div>
</section>
{% endblock %}
