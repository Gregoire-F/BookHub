<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-gray-100 min-h-screen">

<nav class="w-full text-white bg-gray-800 px-6 py-3 flex items-center gap-4">
    <a class="text-xl mr-2" href="{{ path('app_home') }}">{{ ux_icon('bi:house-fill') }}</a>

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <a class="hover:text-gray-300 transition-colors" href="{{ path('app_books_index') }}">Livres</a>
        <a class="hover:text-gray-300 transition-colors" href="{{ path('app_authors_index') }}">Auteurs</a>

        {% if is_granted('ROLE_ADMIN') %}
            <span class="text-gray-500 text-xs">|</span>
            <span class="text-gray-400 text-xs uppercase tracking-wider">Admin :</span>
            <a class="hover:text-gray-300 transition-colors" href="{{ path('app_book_index') }}">Livres</a>
            <a class="hover:text-gray-300 transition-colors" href="{{ path('app_author_index') }}">Auteurs</a>
            <a class="hover:text-gray-300 transition-colors" href="{{ path('app_category_index') }}">Catégories</a>
        {% endif %}

        <a class="ml-auto bg-gray-600 hover:bg-gray-700 rounded-lg px-4 py-2 transition-colors"
           href="{{ path('app_logout') }}">Se déconnecter</a>
    {% else %}
        <div class="ml-auto flex gap-3">
            <a class="bg-gray-600 hover:bg-gray-700 rounded-lg px-4 py-2 transition-colors"
               href="{{ path('app_login') }}">Se connecter</a>
            <a class="bg-blue-500 hover:bg-blue-600 rounded-lg px-4 py-2 transition-colors"
               href="{{ path('app_register') }}">Créer un compte</a>
        </div>
    {% endif %}
</nav>

        {% block body %}{% endblock %}
    </body>
</html>
