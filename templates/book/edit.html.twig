{% extends 'base.html.twig' %}

{% block title %}Modifier - {{ book.title }}{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto mt-8 px-4">
    <a href="{{ path('app_book_index') }}"
       class="text-sm text-gray-500 hover:text-gray-700 transition-colors mb-6 inline-block">
        ← Retour à la liste
    </a>
    <div class="bg-white rounded-xl shadow p-8">
        <h1 class="font-bold text-2xl text-gray-800 mb-6">Modifier le livre</h1>
        {{ include('book/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        <hr class="border-gray-100 mt-6 mb-4">
        {{ include('book/_delete_form.html.twig') }}
    </div>
</section>
{% endblock %}
