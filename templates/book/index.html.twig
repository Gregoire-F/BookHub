{% extends 'base.html.twig' %}

{% block title %}Admin - Livres{% endblock %}

{% block body %}
<section class="max-w-5xl mx-auto mt-8 px-4">
    <div class="flex items-center justify-between mb-6">
        <h1 class="font-bold text-2xl text-gray-800">Livres</h1>
        <a href="{{ path('app_book_new') }}"
           class="bg-blue-500 hover:bg-blue-600 text-white rounded-lg px-4 py-2 text-sm transition-colors cursor-pointer">
            + Nouveau
        </a>
    </div>

    <div class="bg-white rounded-xl shadow overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-gray-50 text-gray-500 uppercase text-xs tracking-wider">
                    <th class="px-4 py-3 text-left">ID</th>
                    <th class="px-4 py-3 text-left">Titre</th>
                    <th class="px-4 py-3 text-left">Année</th>
                    <th class="px-4 py-3 text-left">Description</th>
                    <th class="px-4 py-3 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for book in books %}
                <tr class="border-t border-gray-100 hover:bg-gray-50">
                    <td class="px-4 py-3 text-gray-400">{{ book.id }}</td>
                    <td class="px-4 py-3 font-medium text-gray-800">{{ book.title }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ book.year ? book.year|date('Y') : '—' }}</td>
                    <td class="px-4 py-3 text-gray-500 max-w-xs truncate">{{ book.description }}</td>
                    <td class="px-4 py-3 flex gap-3">
                        <a href="{{ path('app_book_show', {'id': book.id}) }}"
                           class="text-blue-500 hover:text-blue-700 transition-colors">Voir</a>
                        <a href="{{ path('app_book_edit', {'id': book.id}) }}"
                           class="text-gray-500 hover:text-gray-700 transition-colors">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-4 py-6 text-center text-gray-400 italic">Aucun livre trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
